{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Netcred API",
  "description": "Documentacao para clientes e integradores da API Netcred.",
  "colors": {
    "primary": "#1663d9"
  },
  "appearance": {
    "default": "system"
  },
  "api": {
    "openapi": "openapi/openapi.yaml",
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "defaults": "all",
      "languages": ["curl", "javascript", "python"]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Netcred",
        "href": "https://netcredbrasil.com.br/"
      }
    ]
  },
  "navigation": {
    "anchors": [
      {
        "anchor": "Ínicio",
        "icon": "book-open",
        "pages": [
          "intro",
          "por-onde-comecar/index",
          "por-onde-comecar/conceitos-de-graphql",
          "autenticacao/index"
        ]
      },
      {
        "anchor": "API Reference",
        "openapi": "openapi/openapi.yaml"
      }
    ]
  },
  "footer": {
    "socials": {
      "website": "https://netcredbrasil.com.br/"
    }
  }
}
