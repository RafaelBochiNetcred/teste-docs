{
  "name": "netcred-api-mintlify-docs",
  "private": true,
  "scripts": {
    "docs:openapi": "cd .. && DJANGO_DEBUG=False ./.venv/bin/python manage.py spectacular --file mintlify-docs/openapi/openapi.yaml --validate",
    "dev": "npm run docs:openapi && mintlify dev",
    "check": "npm run docs:openapi && mintlify broken-links"
  },
  "devDependencies": {
    "mintlify": "latest"
  }
}
